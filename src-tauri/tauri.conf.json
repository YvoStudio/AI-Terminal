{
  "$schema": "https://raw.githubusercontent.com/nickel-org/tauri/v2/crates/tauri-utils/schema.json",
  "productName": "AI Terminal",
  "version": "0.3.3",
  "identifier": "io.github.yvo-zym.ai-terminal",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1450",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AI Terminal",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 12, "y": 13 },
        "transparent": false,
        "dragDropEnabled": true
      },
      {
        "label": "quick",
        "title": "Quick Terminal",
        "url": "index.html?quick=1",
        "width": 900,
        "height": 380,
        "minWidth": 500,
        "minHeight": 200,
        "decorations": false,
        "transparent": false,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "center": true,
        "resizable": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.icns",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/YvoStudio/AI-Terminal/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUwNEI1RUM2NUMyMDA3RDkKUldUWkJ5QmN4bDVMNE5yV3J0Q1g3UXBuRUgrOHVRUFl4R045RTRwMUZ3WUhjODZ6MDJlMEtOSEUK"
    }
  }
}
